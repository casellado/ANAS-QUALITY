# Accessibilità WCAG 2.1 AA

## Touch target minimo 44×44px — ispettori usano guanti
```tsx
<button className="min-h-[44px] min-w-[44px] px-4 py-3 btn-primary"
        aria-label="Avanza al passo successivo">
  Avanti →
</button>
// ❌ VIETATO — ~28px
<button className="px-2 py-1">›</button>
```

## aria-label — descrittivo e contestuale
```tsx
// ✅ specifico e utile
<button aria-label={`Archivia verbale ${verbale.codice}, stato ${verbale.stato}`}>
  Archivia
</button>
// ❌ VIETATO — inutile per screen reader
<button aria-label="button">›</button>
<button aria-label="click here">Avanti</button>
```

## Live regions
```tsx
// ✅ polite — aggiornamenti background (connessione, polling)
<div role="status" aria-live="polite" aria-atomic="true"
     aria-label={online ? 'Connesso' : 'Offline'}>
  {online ? '● Online' : '⚡ Offline'}
</div>

// ✅ assertive — errori che richiedono attenzione immediata
<div role="alert" aria-live="assertive" id={`errore-${fieldId}`}>
  {errore}
</div>
```

## Wizard — accessibilità completa
```tsx
// Progress bar
<div role="progressbar"
     aria-valuenow={step + 1} aria-valuemin={1} aria-valuemax={totaleStep}
     aria-label={`Compilazione: passo ${step + 1} di ${totaleStep}`} />

// Campo con label + hint + errore collegati
<label htmlFor={`campo-${step.key}`}>
  {step.domanda}
  {step.obbligatorio && <span aria-label="campo obbligatorio"> *</span>}
</label>
<input id={`campo-${step.key}`}
       aria-required={step.obbligatorio}
       aria-describedby={`hint-${step.key} errore-${step.key}`}
       aria-invalid={!!errore} />
<p id={`hint-${step.key}`}>{step.hint}</p>
<p id={`errore-${step.key}`} role="alert">{errore}</p>
```

## Focus management — wizard
```typescript
// ✅ Focus primo input ad ogni avanzamento step
const stepRef = useRef<HTMLDivElement>(null)
useEffect(() => {
  const first = stepRef.current?.querySelector<HTMLElement>(
    'input:not([disabled]), select:not([disabled]), button:not([disabled])'
  )
  first?.focus()
}, [currentStep])
```

## Canvas firma
```tsx
<div role="group" aria-label="Area firma digitale">
  <p id="firma-istr">Firma con il dito o stilo nell'area sottostante</p>
  <canvas role="img" aria-label="Area firma digitale"
          aria-describedby="firma-istr"
          className="touch-none cursor-crosshair" />
</div>
```

## Tabella registro
```tsx
<table role="grid" aria-label="Registro verbali cantiere">
  <caption className="sr-only">Verbali trovati: {verbali.length}</caption>
  <thead><tr>
    <th scope="col" aria-sort="descending">Data</th>
    <th scope="col">Tipo</th>
  </tr></thead>
</table>
```
